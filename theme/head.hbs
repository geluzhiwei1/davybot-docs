</style>

<!-- FancyBox JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>

<script>
    // 初始化 FancyBox
    document.addEventListener('DOMContentLoaded', function() {
        // 绑定 FancyBox 到所有内容区域的图片
        Fancybox.bind('.content img:not(.no-zoom)', {
            // 幻灯片模式 - 同一页面的图片可以左右切换
            groupAll: true,

            // 工具栏按钮
            Toolbar: {
                display: {
                    left: ['infobar'],
                    middle: ['zoomIn', 'zoomOut', 'toggle1to1', 'rotateCCW', 'rotateCW', 'flipX', 'flipY'],
                    right: ['slideshow', 'thumbs', 'close'],
                },
            },

            // 幻灯片自动播放
            slideshow: {
                autoplay: false,
                speed: 3000,
            },

            // 缩略图
            Thumbs: {
                type: 'modern',
            },

            // 动画效果
            hideScrollbar: false,
            compact: false,

            // 点击图片背景关闭
            closeClickOutside: true,

            // 键盘快捷键
            keyboard: {
                Escape: 'close',
                Delete: 'close',
                Backspace: 'close',
                PageUp: 'prev',
                PageDown: 'next',
                ArrowUp: 'prev',
                ArrowDown: 'next',
                ArrowLeft: 'prev',
                ArrowRight: 'next',
            },

            // 图片标题
            caption: function (fancybox, slide) {
                const caption = slide.caption || '';
                return caption;
            },

            // 检测当前语言并应用相应翻译
            l10n: (function() {
                // 从路径检测语言
                const path = window.location.pathname;
                const isEnglish = path.includes('/book-en/') || path.includes('/en/');

                if (isEnglish) {
                    // 英文界面
                    return {
                        CLOSE: 'Close',
                        NEXT: 'Next',
                        PREV: 'Previous',
                        MODAL: 'Press ESC to close',
                        ERROR: 'Failed to load, please try again',
                        IMAGE_ERROR: 'Image failed to load',
                        TOGGLE_ZOOM: 'Zoom',
                        TOGGLE_THUMBS: 'Thumbnails',
                        TOGGLE_SLIDESHOW: 'Slideshow',
                        TOGGLE_FULLSCREEN: 'Fullscreen',
                        DOWNLOAD: 'Download',
                    };
                } else {
                    // 中文界面
                    return {
                        CLOSE: '关闭',
                        NEXT: '下一张',
                        PREV: '上一张',
                        MODAL: '按 ESC 关闭',
                        ERROR: '加载失败，请重试',
                        IMAGE_ERROR: '图片加载失败',
                        TOGGLE_ZOOM: '缩放',
                        TOGGLE_THUMBS: '缩略图',
                        TOGGLE_SLIDESHOW: '幻灯片',
                        TOGGLE_FULLSCREEN: '全屏',
                        DOWNLOAD: '下载',
                    };
                }
            })(),

            // 触摸支持
            dragToClose: true,

            // 图片适应屏幕
            Images: {
                initialSize: 'fit',
            },

            // 全屏选项
            fullscreen: {
                autopan: true,
            },

            // 点击图片切换到下一张
            click: 'next',
        });

        // 动态加载的图片也需要绑定 FancyBox
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.addedNodes.length > 0) {
                    mutation.addedNodes.forEach(function(node) {
                        if (node.nodeType === 1) { // 元素节点
                            const newImages = node.querySelectorAll ? node.querySelectorAll('.content img:not(.no-zoom)') : [];
                            if (newImages.length > 0) {
                                Fancybox.bind(newImages, {
                                    groupAll: true,
                                });
                            }
                        }
                    });
                }
            });
        });

        // 观察内容区域的变化
        const contentArea = document.querySelector('.content');
        if (contentArea) {
            observer.observe(contentArea, {
                childList: true,
                subtree: true
            });
        }
    });
</script>
<!-- End FancyBox 4 -->

